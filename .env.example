TELEGRAM_BOT_TOKEN=your_telegram_bot_token
ALLOWED_USER_IDS=848625725

GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret
GOOGLE_REFRESH_TOKEN=your_refresh_token

TZ=Europe/Moscow
MORNING_NOTIFY_TIME=08:00
DEADLINE_NOTIFY_TIME=09:00
REMINDER_INTERVAL=4h
NODUE_MAX_PER_DAY=1
POLL_INTERVAL=1m
NOTIFY_DB_PATH=./data/notify.db

# HTTP-прокси для Telegram и Google API (опционально)
HTTP_PROXY=http://user:password@host:3128
